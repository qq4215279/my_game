### 直接执行groovy脚本 - 清除机器人等级相关数据
POST {{url}}{{world}}/groovy/evaluate?args=1000000
Content-Type: text/plain

import com.game.business.item.operator.PlayerPackOperator
import com.game.business.item.reward.consts.RewardEnum
import com.game.business.player.manager.PlayerManager
import com.game.business.rank.enums.RankFunc
import com.game.business.rank.enums.RankType
import com.game.framework.core.datasource.DBUtil
import com.game.framework.core.datasource.consts.DSConstants
import com.game.framework.core.log.LogTopic
import com.game.framework.core.redis.RedisUtil
import com.game.framework.core.utils.SpringContextUtils
import com.game.framework.net.server.MessageSender
import com.game.groovy.IGroovyExecutor
import com.game.player.domain.PlayerGameInfoDO
import com.game.player.operator.PlayerGameInfoDOOperator

String SQL = "select player_id from player_pack where item_id = 17000 and count >= #{exp} and player_id in (select id from player_base where robot = 1);"



        // 获取玩家id
        def allPlayerIds = DBUtil.selectSqlList(DSConstants.DAT, SQL, "exp", 50000)
        def ids = allPlayerIds.stream().map(m -> (long) m.get("player_id")).filter(Objects::nonNull).toList()

        def playerManager = PlayerManager.self()
        def playerPackOperator = PlayerPackOperator.self()

        def playerGameInfoDOOperator = SpringContextUtils.getBean(PlayerGameInfoDOOperator.class)

        List<Long> res = new ArrayList<>()

        for (playerId in ids) {
            def player = playerManager.getPlayer(playerId)
            // 非机器人
            if (!player.isRobot()) {
                continue
            }
            res.add(playerId)

            MessageSender.sendRunLater(playerId, () -> {
                def log = LogTopic.ACTION
                def conditionName = ThreadConstants.THREAD_PREFIX_PLAYER + CoreConfig.route(ThreadPoolRouter.getRouteId(playerId)) + "-1"
                log.info("testClearRobotLevelGroovy", "robotId", playerId, "threadName", Thread.currentThread().getName(), "conditionName", conditionName)

                // 1. 清除所有经验
                def playerExp = playerPackOperator.getPlayerPackDO(playerId, RewardEnum.PLAYER_EXP.getItemId())
                if (playerExp != null) {
                    playerExp.setCount(0)
                    playerPackOperator.update(playerExp)
                }

                // 2. 清除vip经验 TODO 针对dev
                def playerVipExp = playerPackOperator.getPlayerPackDO(playerId, RewardEnum.PLAYER_VIP_EXP.getItemId())
                if (playerVipExp != null) {
                    playerVipExp.setCount(0)
                    playerPackOperator.update(playerVipExp)
                }

                // 3. 清除对局数
                def list = playerGameInfoDOOperator.getPlayerGameInfoDOList(playerId)
                for (PlayerGameInfoDO playerGameInfoDO : list) {
                    playerGameInfoDOOperator.delete(playerId, playerGameInfoDO)
                }

                // 4. 删除经验榜
                RedisUtil.zremove(RankFunc.EXP.getRankKey(RankType.TOTAL), playerId);

                // 5. 删除vip经验榜 TODO 针对dev
                RedisUtil.zremove(RankFunc.VIP.getRankKey(RankType.DAILY), playerId);
            }, "clearRobotLevelGroovy", playerId)
        }

        return "total: " + ids.size() + " actual: " + res.size() + " res: " + res



