import com.game.framework.net.server.MessageSender
import com.game.framework.rpc.RpcManager
import com.game.framework.rpc.api.world.ExpAdditionRpcFunc
import com.game.groovy.IGroovyExecutor

    for (int i = 0; i < 100; i++) {
            long playerId1 = 10000002L;
            MessageSender.sendRunLater(playerId1, () -> {
                RpcManager.getProxy(ExpAdditionRpcFunc.class)
                        .syncGetExpActivityAddition(playerId1, 100);
            });

            long playerId2 = 10000020L;
            MessageSender.sendRunLater(playerId2, () -> {
                RpcManager.getProxy(ExpAdditionRpcFunc.class)
                        .syncGetExpActivityAddition(playerId2, 200);
            });
        }