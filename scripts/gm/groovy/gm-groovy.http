### 直接执行groovy脚本 - 更新金币排行榜
POST {{url}}{{world}}/groovy/evaluate?args=1000000
Content-Type: text/plain

import com.game.business.rank.enums.RankFunc
import com.game.framework.core.utils.RandomUtils
import com.game.groovy.IGroovyExecutor
import com.game.business.rank.enums.RankType

      for (playerId in 10000001..< 10000300) {
            var gold = RandomUtils.rollInt(100, 10000)
            RankFunc.GOLD.incr(playerId, gold)
            RankFunc.FRUIT_GOLD.incr(playerId, gold)
        }

     return RankType.DAILY.getCurrPeriodId()




